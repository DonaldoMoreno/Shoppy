# Database
DATABASE_URL=postgresql://shoppy:shoppy_pass@postgres:5432/shoppy_dev?schema=public

# App
JWT_SECRET=change-this-secret
APP_PORT=3001

# Redis
REDIS_URL=redis://redis:6379

# MinIO (S3 stub)
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=shoppy

# Upload validation
UPLOAD_ALLOWED_MIME=image/jpeg,image/png,application/pdf
UPLOAD_MAX_SIZE_BYTES=5242880
UPLOAD_VERIFY_ATTEMPTS=3
UPLOAD_VERIFY_DELAY_MS=300

# Stripe (mock)
STRIPE_API_KEY=sk_test_xxx
STRIPE_CONNECT_CLIENT_ID=ca_xxx

# Risk / platform config
HOLDBACK_RESERVE_PERCENT=7
RELEASE_AFTER_DAYS=3
