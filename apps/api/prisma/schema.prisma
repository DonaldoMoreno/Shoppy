generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  CLIENT
  SHOPPER
  ADMIN
}

enum KycStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum OrderState {
  CREATED
  FUNDED
  PURCHASED
  SHIPPED
  DELIVERED
  COMPLETED
  CANCELLED
  DISPUTED
  REFUNDED
}

enum DisputeType {
  NOT_RECEIVED
  WRONG_ITEM
  DAMAGED
  COUNTERFEIT
}

enum RiskDecisionEnum {
  ALLOW
  REVIEW
  BLOCK
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String?
  role         Role      @default(CLIENT)
  kycStatus    KycStatus @default(UNVERIFIED)
  riskScore    Int       @default(0)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  requests     Request[] @relation("client_requests")
  offers       Offer[]   @relation("shopper_offers")
  ordersAsClient Order[] @relation("client_orders")
  ordersAsShopper Order[] @relation("shopper_orders")
  uploads       Upload[]
}

model Request {
  id             String   @id @default(cuid())
  client         User     @relation(fields: [clientId], references: [id], name: "client_requests")
  clientId       String
  title          String
  description    String?
  budgetCents    Int
  destinationCity String
  category       String
  createdAt      DateTime @default(now())
  offers         Offer[]
}

model Offer {
  id              String   @id @default(cuid())
  request         Request  @relation(fields: [requestId], references: [id])
  requestId       String
  shopper         User     @relation(fields: [shopperId], references: [id], name: "shopper_offers")
  shopperId       String
  itemEstimateCents Int
  shopperFeeCents  Int
  shippingEstimateCents Int
  slaDays          Int
  notes            String?
  createdAt        DateTime @default(now())
  accepted         Boolean  @default(false)
  order            Order?
}

model Order {
  id                    String     @id @default(cuid())
  client                User       @relation(fields: [clientId], references: [id], name: "client_orders")
  clientId              String
  shopper               User       @relation(fields: [shopperId], references: [id], name: "shopper_orders")
  shopperId             String
  offer                 Offer      @relation(fields: [offerId], references: [id])
  offerId               String     @unique
  totalCents            Int
  platformHoldCents     Int
  state                 OrderState @default(CREATED)
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  purchaseReceiptId     String?    @unique
  purchaseReceipt       Upload?    @relation(name: "Order_purchaseReceipt", fields: [purchaseReceiptId], references: [id])
  purchasePhotoId       String?    @unique
  purchasePhoto         Upload?    @relation(name: "Order_purchasePhoto", fields: [purchasePhotoId], references: [id])
  purchaseReceiptAmountCents Int?
  shipmentReceiptId     String?    @unique
  shipmentReceipt       Upload?    @relation(name: "Order_shipmentReceipt", fields: [shipmentReceiptId], references: [id])
  shipmentPhotoId       String?    @unique
  shipmentPhoto         Upload?    @relation(name: "Order_shipmentPhoto", fields: [shipmentPhotoId], references: [id])
  tracking              Tracking?
  dispute               Dispute?
  reviews               Review?
}

model Upload {
  id           String   @id @default(cuid())
  key          String   @unique
  url          String
  mime         String
  size         Int
  uploadedBy   User     @relation(fields: [uploadedById], references: [id])
  uploadedById String
  createdAt    DateTime @default(now())
  // back-relations to Order
  purchaseReceiptFor  Order?   @relation(name: "Order_purchaseReceipt")
  purchasePhotoFor    Order?   @relation(name: "Order_purchasePhoto")
  shipmentReceiptFor  Order?   @relation(name: "Order_shipmentReceipt")
  shipmentPhotoFor    Order?   @relation(name: "Order_shipmentPhoto")
}

model LedgerEntry {
  id         String   @id @default(cuid())
  account    String
  amountCents Int
  reference  String?
  metadata   Json?
  createdAt  DateTime @default(now())
}

model Tracking {
  id            String   @id @default(cuid())
  order         Order    @relation(fields: [orderId], references: [id])
  orderId       String   @unique
  carrier       String
  trackingNumber String
  lastStatus    String
  events        Json     @default("[]")
  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())
}

model Dispute {
  id           String      @id @default(cuid())
  order        Order       @relation(fields: [orderId], references: [id])
  orderId      String      @unique
  openedById   String
  type         DisputeType
  status       String
  evidence     Json?
  resolution   String?
  adminNote    String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

model Review {
  id        String  @id @default(cuid())
  order     Order   @relation(fields: [orderId], references: [id])
  orderId   String  @unique
  clientId  String
  rating    Int
  text      String?
  weight    Float   @default(1.0)
  createdAt DateTime @default(now())
}

model RiskRule {
  id          String  @id @default(cuid())
  code        String  @unique
  description String
  config      Json?
  createdAt   DateTime @default(now())
}

model RiskEvent {
  id        String   @id @default(cuid())
  userId    String?
  orderId   String?
  ruleId    String?
  scoreDelta Int
  details   Json?
  createdAt DateTime @default(now())
}

model RiskDecision {
  id        String   @id @default(cuid())
  orderId   String   @unique
  decision  RiskDecisionEnum
  score     Int
  reasons   Json?
  createdAt DateTime @default(now())
}
